# Tesla Local Control — Environment Config
# Copy to /opt/tesla-web/.env and edit

# Your Tesla VIN (required)
TESLA_VIN=LRW...

# Port to listen on (default: 5000)
TESLA_PORT=5000

# API token for security (optional — set if Orange Pi is on shared WiFi)
TESLA_API_TOKEN=

# Debug mode (0 or 1)
TESLA_DEBUG=0
